---
import { getEntry } from 'astro:content';
import AgendaTimeline from '@components/features/agenda/Timeline.astro';
import MainLayout from '@layouts/MainLayout.astro';

const agendaEntry = await getEntry('agenda', 'home');
if (!agendaEntry) {
	throw new Error('Agenda data not found');
}

const { meta, header, items } = agendaEntry.data;
---

<MainLayout title={meta.title} description={meta.description}>
	<section class="agenda-hero" aria-labelledby="agenda-title">
		<h1 id="agenda-title">
			<span>{header.kicker}</span>
			<strong>{header.title}</strong>
		</h1>
		<p>{header.description}</p>
	</section>

	<AgendaTimeline items={items} />
</MainLayout>

<style>
	.agenda-hero { background: var(--df-page); padding: var(--df-section-y) var(--df-section-x) 1.5rem; text-align: center; }
	.agenda-hero h1 { margin: 0; text-transform: uppercase; }
	.agenda-hero h1 span { display: block; background: linear-gradient(90deg, var(--df-primary), var(--df-accent)); background-clip: text; -webkit-background-clip: text; color: transparent; font-size: clamp(2.9rem, 11vw, 7rem); font-weight: 900; line-height: 0.92; }
	.agenda-hero h1 strong { display: block; color: var(--df-text); font-size: clamp(1.55rem, 6vw, 3.5rem); font-weight: 900; line-height: 1; }
	.agenda-hero p { max-width: 72rem; margin: 1.5rem auto 0; color: var(--df-text-muted); font-size: var(--df-text-body); line-height: 1.45; }

	@media (max-width: 900px) {
		.agenda-hero { padding-top: 7.25rem; }
	}
</style>
