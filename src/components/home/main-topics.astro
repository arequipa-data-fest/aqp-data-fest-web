---
import { BrainCircuit, ChartColumnBig, Cloud, Database } from '@lucide/astro';
import { landingData } from '../../data/landing';

const { mainTopics } = landingData;
const iconMap = { ai: BrainCircuit, database: Database, analytics: ChartColumnBig, cloud: Cloud };
---

<section class="main-topics" aria-labelledby="main-topics-title">
	<div class="main-topics__content">
		<h2 id="main-topics-title" class="main-topics__title">{mainTopics.title}</h2>

		<ul class="main-topics__list">
			{mainTopics.items.map((item) => {
				const Icon = iconMap[item.icon];

				return (
					<li class="main-topics__item">
						<Icon aria-hidden="true" />
						<span>{item.title}</span>
					</li>
				);
			})}
		</ul>
	</div>
</section>

<style>
	.main-topics { background: var(--df-surface); padding: 4rem 3.5rem; }
	.main-topics__content { max-width: 72rem; margin-inline: auto; }
	.main-topics__title { margin: 0 0 3rem; color: var(--df-accent-soft); font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; letter-spacing: 0.2em; text-align: center; text-transform: uppercase; }
	.main-topics__list { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 1rem; margin: 0; padding: 0; list-style: none; }
	.main-topics__item { display: grid; min-width: 0; min-height: 13rem; place-items: center; align-content: center; gap: 1.25rem; padding: 1.5rem; border: 1px solid var(--df-line); border-radius: 0.4rem; background: var(--df-card); color: var(--df-accent); text-align: center; }
	.main-topics__item svg { width: 3rem; height: 3rem; }
	.main-topics__item span { color: var(--df-text); font-size: clamp(1.15rem, 2vw, 1.5rem); font-weight: 700; line-height: 1.3; }
	@media (max-width: 900px) { .main-topics { padding-inline: 1.25rem; } .main-topics__list { grid-template-columns: repeat(2, minmax(0, 1fr)); } }
</style>
