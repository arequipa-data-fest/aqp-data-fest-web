---
import { Coffee, Utensils } from '@lucide/astro';
import { landingData } from '../../data/landing';

const { experience } = landingData;
const iconMap = { lunch: Utensils, coffee: Coffee };
---

<section class="experience" aria-labelledby="experience-title">
	<div class="experience__content">
		<h2 id="experience-title" class="experience__title">{experience.title}</h2>

		<ul class="experience__list">
			{experience.items.map((item) => {
				const Icon = iconMap[item.icon];

				return (
					<li class="experience__card">
						<div class="experience__icon" aria-hidden="true"><Icon /></div>
						<h3>{item.title}</h3>
						<p>{item.description}</p>
					</li>
				);
			})}
		</ul>
	</div>
</section>

<style>
	.experience { background: var(--df-page); padding: 4rem 3.5rem; }
	.experience__content { max-width: 72rem; margin-inline: auto; }
	.experience__title { margin: 0 0 3rem; background: linear-gradient(90deg, var(--df-primary), var(--df-accent)); background-clip: text; -webkit-background-clip: text; color: transparent; font-size: clamp(2rem, 4vw, 3.5rem); font-weight: 800; letter-spacing: 0.2em; text-align: center; text-transform: uppercase; }
	.experience__list { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 1.5rem; margin: 0; padding: 0; list-style: none; }
	.experience__card { min-height: 100%; padding: 2rem; border: 1px solid var(--df-line); border-top: 2px solid var(--df-primary); border-radius: 0.4rem; background: var(--df-card); }
	.experience__card:nth-child(even) { border-top-color: var(--df-accent); }
	.experience__icon { display: grid; width: 3.5rem; height: 3.5rem; place-items: center; border: 1px solid var(--df-primary); border-radius: 0.4rem; color: var(--df-primary); }
	.experience__card:nth-child(even) .experience__icon { border-color: var(--df-accent); color: var(--df-accent); }
	.experience__icon svg { width: 1.75rem; height: 1.75rem; }
	.experience__card h3 { margin: 1.5rem 0 0; color: var(--df-text); font-size: clamp(1.5rem, 2.5vw, 2rem); font-weight: 800; }
	.experience__card p { margin: 1rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); line-height: 1.5; }
	@media (max-width: 768px) { .experience { padding-inline: 1.25rem; } .experience__list { grid-template-columns: 1fr; } }
</style>
