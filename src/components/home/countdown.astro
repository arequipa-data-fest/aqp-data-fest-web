---
import DataNetworkDivider from '../ui/data-network-divider.astro';
import type { CollectionEntry } from 'astro:content';

interface Props {
	countdown: CollectionEntry<'landing'>['data']['countdown'];
}

const { countdown } = Astro.props;
---

<section class="countdown" aria-label={countdown.ariaLabel} data-countdown data-target-date={countdown.targetDate}>
	<div class="countdown__transition" aria-hidden="true">
		<DataNetworkDivider />
	</div>

	<div class="countdown__header">
		<strong>{countdown.inscritos}</strong>
		<span>{countdown.inscritosLabel}</span>
	</div>

	<div class="countdown__grid">
		{countdown.items.map((item) => (
			<div class="countdown__card">
				<strong data-countdown-value={item.key}>00</strong>
				<span>{item.label}</span>
			</div>
		))}
	</div>
</section>

<script>
	const countdowns = document.querySelectorAll<HTMLElement>('[data-countdown]');

	for (const countdown of countdowns) {
		const targetDate = new Date(countdown.dataset.targetDate ?? '').getTime();
		const values = {
			days: countdown.querySelector<HTMLElement>('[data-countdown-value="days"]'),
			hours: countdown.querySelector<HTMLElement>('[data-countdown-value="hours"]'),
			minutes: countdown.querySelector<HTMLElement>('[data-countdown-value="minutes"]'),
			seconds: countdown.querySelector<HTMLElement>('[data-countdown-value="seconds"]'),
		};

		if (!Number.isFinite(targetDate) || Object.values(values).some((value) => value === null)) continue;

		const pad = (value: number) => String(value).padStart(2, '0');

		const updateCountdown = () => {
			const diff = Math.max(targetDate - Date.now(), 0);
			const days = Math.floor(diff / (1000 * 60 * 60 * 24));
			const hours = Math.floor((diff / (1000 * 60 * 60)) % 24);
			const minutes = Math.floor((diff / (1000 * 60)) % 60);
			const seconds = Math.floor((diff / 1000) % 60);

			values.days!.textContent = pad(days);
			values.hours!.textContent = pad(hours);
			values.minutes!.textContent = pad(minutes);
			values.seconds!.textContent = pad(seconds);
		};

		updateCountdown();
		window.setInterval(updateCountdown, 1000);
	}
</script>

<style>
	.countdown { position: relative; isolation: isolate; overflow: hidden; background: var(--df-page); padding: 9rem 3.5rem 4rem; text-align: center; }
	.countdown__transition { position: absolute; z-index: 0; inset: 0 0 auto; height: 12rem; overflow: hidden; pointer-events: none; }
	.countdown__transition::after { content: ''; position: absolute; inset: 0; background: linear-gradient(180deg, transparent 25%, var(--df-page)); }
	.countdown__header, .countdown__grid { position: relative; z-index: 1; }
	.countdown__header strong { display: block; color: var(--df-primary); font-size: clamp(4rem, 9vw, 8rem); font-weight: 900; line-height: 0.9; }
	.countdown__header span { display: block; margin-top: 0.75rem; color: var(--df-text); font-size: clamp(1.5rem, 3vw, 2.2rem); font-weight: 800; }
	.countdown__grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.75rem; max-width: 64rem; margin: 2rem auto 0; }
	.countdown__card { border-radius: 0.6rem; background: var(--df-text); padding: 1.25rem; color: var(--df-page); }
	.countdown__card strong { display: block; font-size: clamp(3rem, 5vw, 4.5rem); font-weight: 900; line-height: 1; }
	.countdown__card span { display: block; margin-top: 0.35rem; font-size: var(--df-text-body); }
	@media (max-width: 768px) { .countdown { padding: 7rem 1.25rem 4rem; } .countdown__transition { height: 9rem; } .countdown__grid { grid-template-columns: repeat(2, 1fr); } }
</style>
