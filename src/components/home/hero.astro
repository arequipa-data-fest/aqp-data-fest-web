---
import { landingData } from '../../data/landing';
import { siteConfig } from '../../data/site';

const { hero } = landingData;

const registrationHref = siteConfig.registrationUrl || hero.primaryCta.href;
const informativeGroupHref =
	siteConfig.informativeGroupUrl || hero.secondaryCta.href;

const isExternalRegistration = registrationHref.startsWith('http');
const isExternalGroup = informativeGroupHref.startsWith('http');
---

<section class="hero" aria-labelledby="landing-title">
	<img class="hero__logo-bg" src="/logos/LOGO-LIMPIO.png" alt="" loading="eager" />

	<div class="hero__copy">
		<h1 id="landing-title" class="hero__title">
			<span>{hero.titlePrefix}</span>
			<strong>{hero.titleHighlight}</strong>
		</h1>

		<p class="hero__description">{hero.description}</p>

		<dl class="hero__details">
			<div class="hero__detail">
				<div class="hero__icon" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M8 2v4M16 2v4M3 10h18M5 4h14a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2Z" />
					</svg>
				</div>
				<div>
					<dt>{hero.date.label}</dt>
					<dd>{hero.date.value}</dd>
				</div>
			</div>

			<div class="hero__detail hero__detail--accent">
				<div class="hero__icon hero__icon--accent" aria-hidden="true">
					<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M21 10c0 7-9 12-9 12S3 17 3 10a9 9 0 1 1 18 0Z" />
						<circle cx="12" cy="10" r="3" />
					</svg>
				</div>
				<div>
					<dt>{hero.location.label}</dt>
					<dd>
						{hero.location.value.map((line) => (
							<Fragment>{line}<br /></Fragment>
						))}
					</dd>
				</div>
			</div>
		</dl>

		<div class="hero__actions">
			<a
				class="hero__action hero__action--primary"
				href={registrationHref}
				target={isExternalRegistration ? '_blank' : undefined}
				rel={isExternalRegistration ? 'noopener noreferrer' : undefined}
			>
				{hero.primaryCta.label}
				<span aria-hidden="true">→</span>
			</a>

			<a
				class="hero__action hero__action--secondary"
				href={informativeGroupHref}
				target={isExternalGroup ? '_blank' : undefined}
				rel={isExternalGroup ? 'noopener noreferrer' : undefined}
			>
				{hero.secondaryCta.label}
				<span aria-hidden="true">▣</span>
			</a>
		</div>

	</div>
</section>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: minmax(0, 1fr) minmax(0, 43rem);
		align-items: center;
		gap: 2rem;
		min-height: calc(100vh - 8rem);
		overflow: hidden;
		background: var(--df-page);
		padding: 2.5rem 3.5rem;
	}

	.hero::before {
		content: '';
		position: absolute;
		inset: 0;
		background: radial-gradient(circle at 72% 22%, var(--df-primary-soft), transparent 28rem);
		pointer-events: none;
	}

	.hero__logo-bg {
		position: relative;
		z-index: 1;
		justify-self: center;
		align-self: center;
		width: min(48rem, 48vw);
		height: auto;
		opacity: 0.95;
		pointer-events: none;
	}

	.hero__copy {
		position: relative;
		z-index: 2;
		width: 100%;
		max-width: 43rem;
		text-align: center;
	}

	.hero__title {
		margin: 0;
		color: var(--df-text);
		font-size: var(--df-text-hero-prefix);
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: -0.03em;
	}

	.hero__title span {
		display: block;
	}

	.hero__title strong {
		display: block;
		background: linear-gradient(90deg, var(--df-primary), var(--df-accent));
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		font-size: var(--df-text-hero);
		line-height: 0.9;
	}

	.hero__description {
		max-width: 39rem;
		margin: 2rem auto 1.25rem;
		color: var(--df-text-muted);
		font-size: var(--df-text-body);
		line-height: 1.25;
	}

	.hero__details {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
	}

	.hero__detail {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 1.4rem;
		min-height: 7.5rem;
		padding: 0.9rem 1.2rem;
		border: 1px solid var(--df-line);
		border-radius: 0.45rem;
		background: var(--df-card);
		text-align: left;
	}

	.hero__detail--accent {
		border-color: color-mix(in srgb, var(--df-primary) 50%, var(--df-line));
	}

	.hero__icon {
		display: grid;
		place-items: center;
		width: 6rem;
		height: 6rem;
		border: 1px solid var(--df-accent-soft);
		border-radius: 0.6rem;
		color: var(--df-accent-soft);
	}

	.hero__icon--accent {
		border-color: var(--df-primary);
		color: var(--df-text-muted);
	}

	.hero__icon svg {
		width: 2rem;
		height: 2rem;
	}

	.hero__detail dt {
		display: block;
		color: var(--df-text-muted);
		font-size: var(--df-text-label);
		font-weight: 800;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.hero__detail dd {
		margin: 0.4rem 0 0;
		display: block;
		color: var(--df-text);
		font-size: var(--df-text-body);
		font-weight: 700;
		line-height: 1.45;
	}


	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin-top: 1.75rem;
	}

	.hero__action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: 3.6rem;
		padding: 0.9rem 2rem;
		font-size: 1.5rem;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0.03em;
	}

	.hero__action--primary {
		background: var(--df-primary);
		color: var(--df-on-primary);
		box-shadow: 0 0 18px color-mix(in srgb, var(--df-primary) 45%, transparent);
	}

	.hero__action--secondary {
		border: 1px solid var(--df-accent);
		color: var(--df-accent);
	}

	.hero__action:focus-visible {
		outline: 2px solid var(--df-accent);
		outline-offset: 4px;
	}

	@media (max-width: 900px) {
		.hero {
			grid-template-columns: 1fr;
			min-height: auto;
			padding: 4rem 1.25rem;
		}

		.hero__logo-bg {
			position: absolute;
			left: 50%;
			top: 50%;
			transform: translate(-50%, -50%);
			width: 42rem;
			opacity: 0.35;
		}

		.hero__copy {
			margin-inline: auto;
		}

		.hero__details {
			grid-template-columns: 1fr;
		}

		.hero__actions {
			flex-direction: column;
			align-items: stretch;
		}

		.hero__action {
			width: 100%;
			min-width: 0;
		}
	}
</style>
