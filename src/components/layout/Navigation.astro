---
import { navigationLinks, siteConfig } from "@config/site";
import { ArrowRight } from "@lucide/astro";

const registrationHref = siteConfig.registrationUrl || "#registro";
const isExternalRegistration = siteConfig.registrationUrl.startsWith("http");
const currentPath = Astro.url.pathname;
const { logo, navigation } = siteConfig;
---

<header class="nav-shell">
  <a class="skip-link" href="#main-content">{navigation.skipLinkLabel}</a>

  <div class="nav-container">
    <a class="nav-logo" href="/" aria-label={logo.alt}>
      <img
        src={siteConfig.logoUrl}
        alt={logo.alt}
        width={logo.width}
        height={logo.height}
        fetchpriority="high"
      />
    </a>

    <nav class="nav-links hidden xl:flex" aria-label={navigation.mainAriaLabel}>
      {
        navigationLinks.map((link) => {
          const isActive = currentPath === link.href;

          return (
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={["nav-link", { "nav-link--active": isActive }]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <a
      class="nav-cta nav-cta--desktop hidden xl:inline-flex"
      href={registrationHref}
      target={isExternalRegistration ? "_blank" : undefined}
      rel={isExternalRegistration ? "noopener noreferrer" : undefined}
    >
      {navigation.registrationLabel}
      <ArrowRight class="nav-cta__icon" aria-hidden="true" />
    </a>

    <details class="nav-mobile xl:hidden">
      <summary class="nav-menu-toggle">
        <span class="sr-only">{navigation.mobileMenuLabel}</span>

        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </summary>

      <nav class="nav-mobile-panel" aria-label={navigation.mobileAriaLabel}>
        <ul>
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={currentPath === link.href ? "page" : undefined}
                  class="nav-mobile-link"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <a
          class="nav-cta nav-cta--mobile"
          href={registrationHref}
          target={isExternalRegistration ? "_blank" : undefined}
          rel={isExternalRegistration ? "noopener noreferrer" : undefined}
        >
          {navigation.registrationLabel}
          <ArrowRight class="nav-cta__icon" aria-hidden="true" />
        </a>
      </nav>
    </details>
  </div>
</header>

<style>
  .nav-shell {
    position: relative;
    z-index: 50;
    background: var(--df-navigation);
    box-shadow: 0 8px 24px rgb(0 0 0 / 20%);
    backdrop-filter: blur(0.75rem);
  }

  .nav-container {
    display: flex;
    min-height: 5rem;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
		min-width: 0;
    padding: 0.75rem 1.25rem;
  }

  .nav-logo {
    flex-shrink: 0;
  }

  .nav-logo img {
    display: block;
    width: 10rem;
    height: auto;
  }

  .nav-links {
    align-items: center;
    gap: 1.5rem;
		min-width: 0;
  }

  .nav-link {
    border-bottom: 2px solid transparent;
    padding-bottom: 0.25rem;
    color: var(--df-on-primary);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }

  .nav-link:hover,
  .nav-link--active {
    border-color: var(--df-accent);
    color: var(--df-accent);
  }

  .nav-cta {
    align-items: center;
    justify-content: center;
    background: var(--df-primary);
    color: var(--df-on-primary);
    box-shadow: 0 0 10px var(--df-primary);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 0.025em;
		max-inline-size: 100%;
		text-align: center;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .nav-cta:hover {
    background: var(--df-primary-hover);
  }

  .nav-cta--desktop {
    padding: 1rem 1.75rem;
  }

  .nav-cta__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .nav-mobile {
    position: relative;
  }

  .nav-menu-toggle {
    display: flex;
    width: 2.75rem;
    height: 2.75rem;
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--df-accent);
    color: var(--df-accent);
  }

  .nav-menu-toggle::-webkit-details-marker {
    display: none;
  }

  .nav-menu-toggle svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .nav-mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.75rem);
		width: min(18rem, calc(100vw - 2.5rem));
    padding: 1rem;
    border: 1px solid rgb(255 255 255 / 10%);
    background: var(--df-navigation);
    box-shadow: 0 8px 24px rgb(0 0 0 / 20%);
  }

  .nav-mobile-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.75rem;
    color: var(--df-on-primary);
    font-size: 1.5rem;
    font-weight: 600;
    text-decoration: none;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link[aria-current="page"] {
    background: rgb(255 255 255 / 5%);
    color: var(--df-accent);
  }

  .nav-cta--mobile {
    display: flex;
    margin-top: 1rem;
    padding: 0.75rem;
  }

  .nav-link:focus-visible,
  .nav-cta:focus-visible,
  .nav-menu-toggle:focus-visible,
  .nav-mobile-link:focus-visible {
    outline: 2px solid var(--df-accent);
    outline-offset: 4px;
  }

  @media (min-width: 640px) {
    .nav-container {
      padding-inline: 2rem;
    }

    .nav-logo img {
      width: 13rem;
    }
  }

  @media (min-width: 1280px) {
    .nav-container {
      min-height: 6rem;
      gap: 1rem;
      padding: 1rem 2.5rem;
    }

    .nav-logo img {
      width: 18rem;
    }
  }
</style>
