---
import { getImagePath } from "@config/assets";
import { navigationLinks, siteConfig } from "@config/site";
import { ArrowRight } from "@lucide/astro";

const registrationHref = siteConfig.registrationUrl || "#registro";
const isExternalRegistration = siteConfig.registrationUrl.startsWith("http");
const currentPath = Astro.url.pathname;
const { logo, navigation } = siteConfig;
---

<header class="nav-shell" data-navigation>
  <a class="skip-link" href="#main-content">{navigation.skipLinkLabel}</a>

  <div class="nav-container">
    <a class="nav-logo" href="/" aria-label={logo.alt}>
      <img
        class="nav-logo-img"
        src={getImagePath(siteConfig.logoPublicId, {
          width: 449,
          height: 129,
          crop: "fit",
        })}
        alt={logo.alt}
        width={449}
        height={129}
        fetchpriority="high"
      />
    </a>

    <nav class="nav-links hidden xl:flex" aria-label={navigation.mainAriaLabel}>
      {
        navigationLinks.map((link) => {
          const isActive = currentPath === link.href;

          return (
            <a
              href={link.href}
              aria-current={isActive ? "page" : undefined}
              class:list={["nav-link", { "nav-link--active": isActive }]}
            >
              {link.label}
            </a>
          );
        })
      }
    </nav>

    <a
      class="nav-cta nav-cta--desktop hidden xl:inline-flex"
      href={registrationHref}
      target={isExternalRegistration ? "_blank" : undefined}
      rel={isExternalRegistration ? "noopener noreferrer" : undefined}
    >
      {navigation.registrationLabel}
      <ArrowRight class="nav-cta__icon" aria-hidden="true" />
    </a>

    <details class="nav-mobile xl:hidden">
      <summary class="nav-menu-toggle">
        <span class="sr-only">{navigation.mobileMenuLabel}</span>

        <svg
          aria-hidden="true"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M4 7h16M4 12h16M4 17h16"></path>
        </svg>
      </summary>

      <nav class="nav-mobile-panel" aria-label={navigation.mobileAriaLabel}>
        <ul>
          {
            navigationLinks.map((link) => (
              <li>
                <a
                  href={link.href}
                  aria-current={currentPath === link.href ? "page" : undefined}
                  class="nav-mobile-link"
                >
                  {link.label}
                </a>
              </li>
            ))
          }
        </ul>

        <a
          class="nav-cta nav-cta--mobile"
          href={registrationHref}
          target={isExternalRegistration ? "_blank" : undefined}
          rel={isExternalRegistration ? "noopener noreferrer" : undefined}
        >
          {navigation.registrationLabel}
          <ArrowRight class="nav-cta__icon" aria-hidden="true" />
        </a>
      </nav>
    </details>
  </div>
</header>

<script>
  const win = window as Window & {
    __dfNavBound?: boolean;
    __dfNavUpdate?: () => void;
  };

  const navigation = document.querySelector<HTMLElement>("[data-navigation]");

  if (navigation) {
    const updateNavigation = () => {
      navigation.classList.toggle("nav-shell--scrolled", window.scrollY > 8);
    };

    win.__dfNavUpdate = updateNavigation;
    updateNavigation();

    if (!win.__dfNavBound) {
      window.addEventListener("scroll", updateNavigation, { passive: true });
      document.addEventListener("astro:page-load", () => {
        win.__dfNavUpdate?.();
      });
      win.__dfNavBound = true;
    }
  }
</script>

<style>
  .nav-shell {
    position: fixed;
    top: 0;
    right: 0;
    left: 0;
    z-index: 50;
    border-bottom: 1px solid transparent;
    background: transparent;
    transition:
      background 180ms ease,
      border-color 180ms ease,
      box-shadow 180ms ease,
      -webkit-backdrop-filter 180ms ease,
      backdrop-filter 180ms ease;
  }

  .nav-shell--scrolled,
  .nav-shell:has(.nav-mobile[open]) {
    border-color: rgb(255 255 255 / 8%);
    background: rgb(5 5 6 / 42%);
    box-shadow: 0 0.75rem 2rem rgb(0 0 0 / 18%);
    -webkit-backdrop-filter: blur(0.85rem);
    backdrop-filter: blur(0.85rem);
  }

  .nav-container {
    display: flex;
    min-height: 4.75rem;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
		min-width: 0;
    padding: 0.75rem var(--df-section-x);
  }

  .nav-logo {
    flex-shrink: 0;
  }

  .nav-logo-img {
    display: block;
    width: clamp(8.5rem, 34vw, 10rem);
    height: auto;
    max-width: none !important;
    max-height: none !important;
    aspect-ratio: auto !important;
    object-fit: contain !important;
  }

  .nav-links {
    align-items: center;
    gap: 1.5rem;
		min-width: 0;
  }

  .nav-link {
    border-bottom: 2px solid transparent;
    padding-bottom: 0.25rem;
    color: var(--df-on-primary);
    font-size: 1.125rem;
    font-weight: 600;
    text-decoration: none;
    transition:
      color 150ms ease,
      border-color 150ms ease;
  }

  .nav-link:hover,
  .nav-link--active {
    border-color: var(--df-accent);
    color: var(--df-accent);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: var(--df-touch-target);
    background: var(--df-primary);
    color: var(--df-on-primary);
    box-shadow: 0 0 10px var(--df-primary);
    font-size: clamp(0.95rem, 0.9rem + 0.2vw, 1.125rem);
    font-weight: 700;
    letter-spacing: 0;
		max-inline-size: 100%;
		white-space: nowrap;
		text-align: center;
    text-decoration: none;
    transition: background 150ms ease;
  }

  .nav-cta:hover {
    background: var(--df-primary-hover);
  }

  .nav-cta--desktop {
    padding: 0.85rem 1.25rem;
  }

  .nav-cta__icon {
    width: 1.25rem;
    height: 1.25rem;
    flex: 0 0 auto;
  }

  .nav-mobile {
    position: relative;
  }

  .nav-menu-toggle {
    display: flex;
    width: var(--df-touch-target);
    height: var(--df-touch-target);
    cursor: pointer;
    list-style: none;
    align-items: center;
    justify-content: center;
    border: 1px solid var(--df-accent);
    color: var(--df-accent);
  }

  .nav-menu-toggle::-webkit-details-marker {
    display: none;
  }

  .nav-menu-toggle svg {
    width: 1.5rem;
    height: 1.5rem;
  }

  .nav-mobile-panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.75rem);
		width: min(20rem, calc(100vw - (var(--df-section-x) * 2)));
    padding: 1rem;
    border: 1px solid rgb(255 255 255 / 10%);
    background: rgb(5 5 6 / 84%);
    box-shadow: 0 8px 24px rgb(0 0 0 / 20%);
    -webkit-backdrop-filter: blur(0.85rem);
    backdrop-filter: blur(0.85rem);
  }

  .nav-mobile-panel ul {
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .nav-mobile-link {
    display: block;
    padding: 0.85rem 0.75rem;
    color: var(--df-on-primary);
    font-size: 1.05rem;
    font-weight: 600;
    text-decoration: none;
  }

  .nav-mobile-link:hover,
  .nav-mobile-link[aria-current="page"] {
    background: rgb(255 255 255 / 5%);
    color: var(--df-accent);
  }

  .nav-cta--mobile {
    display: flex;
    margin-top: 1rem;
    width: 100%;
    padding: 0.85rem 1rem;
  }

  .nav-link:focus-visible,
  .nav-cta:focus-visible,
  .nav-menu-toggle:focus-visible,
  .nav-mobile-link:focus-visible {
    outline: 2px solid var(--df-accent);
    outline-offset: 4px;
  }

  @media (min-width: 640px) {
    .nav-logo-img {
      width: 13rem;
    }
  }

  @media (max-width: 420px) {
    .nav-container {
      gap: 0.5rem;
    }

    .nav-logo-img {
      width: clamp(7.5rem, 32vw, 8.75rem);
    }

    .nav-mobile-panel {
      width: min(18rem, calc(100vw - (var(--df-section-x) * 2)));
    }

    .nav-cta--mobile {
      font-size: 0.95rem;
      padding-inline: 0.9rem;
    }
  }

  @media (min-width: 1280px) {
    .nav-container {
      min-height: 5.6rem;
      gap: 1rem;
      padding: 1rem var(--df-section-x);
    }

    .nav-logo-img {
      width: 14rem !important;
    }

    .nav-link,
    .nav-cta {
      font-size: 1.25rem;
    }
  }
</style>
