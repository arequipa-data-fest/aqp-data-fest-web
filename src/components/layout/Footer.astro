---
import { CldImage } from "astro-cloudinary";
import { siteConfig } from "@config/site";
import { ArrowRight, MessageCircle } from "@lucide/astro";

const registrationHref = siteConfig.registrationUrl || "#registro";
const informativeGroupHref =
  siteConfig.informativeGroupUrl || "#grupo-informativo";
const isExternalRegistration = siteConfig.registrationUrl.startsWith("http");
const isExternalGroup = siteConfig.informativeGroupUrl.startsWith("http");
const { footer } = siteConfig;
---

<footer class="footer-shell" aria-label={footer.ariaLabel}>
  <div class="footer-content">
    <section class="footer-info">
      <h2>{footer.title}</h2>

      <div class="footer-actions">
        <a
          class="footer-button footer-button--primary"
          href={registrationHref}
          target={isExternalRegistration ? "_blank" : undefined}
          rel={isExternalRegistration ? "noopener noreferrer" : undefined}
        >
          {footer.registrationLabel}
          <ArrowRight class="footer-button__icon" aria-hidden="true" />
        </a>
        <a
          class="footer-button footer-button--outline"
          href={informativeGroupHref}
          target={isExternalGroup ? "_blank" : undefined}
          rel={isExternalGroup ? "noopener noreferrer" : undefined}
        >
          {footer.groupLabel}
          <MessageCircle class="footer-button__icon" aria-hidden="true" />
        </a>
      </div>
    </section>

    <CldImage
      class="footer-network"
      src={footer.networkPublicId}
      alt=""
      width={860}
      height={860}
      loading="lazy"
    />
  </div>

  <p class="footer-copy">{footer.copyright}</p>
</footer>

<style>
  .footer-shell {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--df-page) 94%, transparent),
        color-mix(in srgb, var(--df-surface) 64%, transparent)
      );
  }
  .footer-content {
    position: relative;
    min-height: clamp(18rem, 28vw, 22rem);
    padding: clamp(2.5rem, 4vw, 3.5rem) clamp(1.25rem, 5vw, 4rem)
      clamp(1.25rem, 3vw, 1.75rem);
  }
  .footer-info {
    position: relative;
    z-index: 2;
    max-width: none;
    width: min(58%, 42rem);
    min-width: 0;
  }
  .footer-info h2 {
    margin: 0;
    color: var(--df-on-primary);
    font-size: 1.55rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.35rem;
  }
  .footer-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: 3.15rem;
    padding: 0.75rem 1.45rem;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0;
		max-inline-size: 100%;
		text-align: center;
  }
  .footer-button--primary {
    background: var(--df-primary);
    color: var(--df-on-primary);
    box-shadow: 0 0 18px color-mix(in srgb, var(--df-primary) 45%, transparent);
  }
  .footer-button--outline {
    border: 1px solid var(--df-accent);
    color: var(--df-accent);
  }
  .footer-button__icon {
    width: 1.2rem;
    height: 1.2rem;
    flex: 0 0 auto;
  }
  .footer-logo {
    display: block;
    width: min(28rem, 90vw) !important;
    max-width: none !important;
    height: auto !important;
    max-height: none !important;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    margin-top: 2rem;
  }
  .footer-network {
    position: absolute;
    right: clamp(-8rem, -8vw, -2rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    width: min(42rem, 48vw) !important;
    max-width: none !important;
    height: auto !important;
    max-height: none !important;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    pointer-events: none;
  }
  .footer-copy {
    position: relative;
    z-index: 2;
    margin: 0;
    padding: 0 2rem 1.4rem;
    color: var(--df-accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0;
    text-align: center;
  }
  .footer-button:focus-visible {
    outline: 2px solid var(--df-accent);
    outline-offset: 4px;
  }
  @media (max-width: 768px) {
    .footer-content {
      min-height: auto;
      padding: 2.5rem 1.25rem 8.5rem;
    }
    .footer-actions {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-info {
      width: 100%;
    }
    .footer-button {
      width: 100%;
    }
    .footer-network {
      right: 0;
      bottom: 1.25rem;
      top: auto;
      transform: none;
      width: min(34rem, 118vw) !important;
      opacity: 0.52;
    }
    .footer-copy {
      padding-inline: 1.25rem;
    }
  }

  @media (min-width: 769px) {
    .footer-info h2 {
      font-size: 2.35rem;
    }

    .footer-button {
      font-size: 1.15rem;
    }
  }

  @media (min-width: 1280px) {
    .footer-info h2 {
      font-size: 2.75rem;
    }

    .footer-button {
      font-size: 1.2rem;
    }
  }
</style>
