---
import { getImagePath } from "@config/assets";
import { siteConfig } from "@config/site";
import { ArrowRight, MessageCircle } from "@lucide/astro";

const registrationHref = siteConfig.registrationUrl || "#registro";
const informativeGroupHref =
  siteConfig.informativeGroupUrl || "#grupo-informativo";
const isExternalRegistration = siteConfig.registrationUrl.startsWith("http");
const isExternalGroup = siteConfig.informativeGroupUrl.startsWith("http");
const { footer } = siteConfig;
---

<footer class="footer-shell" aria-label={footer.ariaLabel}>
  <div class="footer-content">
    <section class="footer-info">
      <h2>{footer.title}</h2>

      <div class="footer-actions">
        <a
          class="footer-button footer-button--primary"
          href={registrationHref}
          target={isExternalRegistration ? "_blank" : undefined}
          rel={isExternalRegistration ? "noopener noreferrer" : undefined}
        >
          {footer.registrationLabel}
          <ArrowRight class="footer-button__icon" aria-hidden="true" />
        </a>
        <a
          class="footer-button footer-button--outline"
          href={informativeGroupHref}
          target={isExternalGroup ? "_blank" : undefined}
          rel={isExternalGroup ? "noopener noreferrer" : undefined}
        >
          {footer.groupLabel}
          <MessageCircle class="footer-button__icon" aria-hidden="true" />
        </a>
      </div>
    </section>

    <img
      class="footer-network"
      src={getImagePath(footer.networkPublicId, {
        width: 860,
        height: 860,
        crop: "fit",
      })}
      alt=""
      width={860}
      height={860}
      loading="lazy"
    />
  </div>

  <p class="footer-copy">{footer.copyright}</p>
</footer>

<style>
  .footer-shell {
    position: relative;
    overflow: hidden;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--df-page) 94%, transparent),
        color-mix(in srgb, var(--df-surface) 64%, transparent)
      );
  }
  .footer-content {
    position: relative;
    min-height: 28rem;
    display: grid;
    align-items: start;
    padding: var(--df-section-y) var(--df-section-x) 2rem;
  }
  .footer-info {
    position: relative;
    z-index: 2;
    max-width: none;
    width: min(100%, 48rem);
    min-width: 0;
  }
  .footer-info h2 {
    margin: 0;
    color: var(--df-on-primary);
    font-size: 1.55rem;
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: 0;
    text-transform: uppercase;
  }
  .footer-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.35rem;
  }
  .footer-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    min-height: var(--df-touch-target);
    padding: 0.9rem 1.35rem;
    font-size: clamp(1rem, 0.95rem + 0.25vw, 1.2rem);
    font-weight: 700;
    text-decoration: none;
    letter-spacing: 0;
		max-inline-size: 100%;
		white-space: nowrap;
		text-align: center;
  }
  .footer-button--primary {
    background: var(--df-primary);
    color: var(--df-on-primary);
    box-shadow: 0 0 18px color-mix(in srgb, var(--df-primary) 45%, transparent);
  }
  .footer-button--outline {
    border: 1px solid var(--df-accent);
    color: var(--df-accent);
  }
  .footer-button__icon {
    width: 1.2rem;
    height: 1.2rem;
    flex: 0 0 auto;
  }
  .footer-logo {
    display: block;
    width: min(28rem, 90vw) !important;
    max-width: none !important;
    height: auto !important;
    max-height: none !important;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    margin-top: 2rem;
  }
  .footer-network {
    position: absolute;
    right: clamp(-8rem, -8vw, -2rem);
    top: 50%;
    transform: translateY(-50%);
    z-index: 1;
    width: min(54rem, 54vw);
    height: auto;
    max-width: none !important;
    max-height: none !important;
    aspect-ratio: auto !important;
    object-fit: contain !important;
    pointer-events: none;
    animation: footerDrift 14s ease-in-out infinite alternate;
  }
  .footer-copy {
    position: relative;
    z-index: 2;
    margin: 0;
    padding: 0 var(--df-section-x) 2rem;
    color: var(--df-accent);
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0;
    text-align: center;
  }
  .footer-button:focus-visible {
    outline: 2px solid var(--df-accent);
    outline-offset: 4px;
  }
  @media (max-width: 768px) {
    .footer-content {
      min-height: auto;
      padding: var(--df-section-y) var(--df-section-x) 11rem;
    }
    .footer-actions {
      flex-direction: column;
      align-items: flex-start;
    }
    .footer-info {
      width: 100%;
    }
    .footer-button {
      width: 100%;
    }
    .footer-network {
      right: -11rem;
      bottom: 2rem;
      top: auto;
      width: min(40rem, 125vw);
      opacity: 0.7;
      transform: none;
      animation: none;
    }
  }

  @media (max-width: 420px) {
    .footer-button {
      font-size: 0.95rem;
      padding-inline: 1rem;
    }
  }

  @media (min-width: 769px) {
    .footer-info h2 {
      font-size: 2.35rem;
    }

    .footer-button {
      font-size: 1.15rem;
    }
  }

  @media (min-width: 1280px) {
    .footer-info h2 {
      font-size: 2.75rem;
    }

    .footer-button {
      font-size: 1.2rem;
    }
  }

  @keyframes footerDrift {
    0% {
      transform: translateY(-50%) translateX(0);
    }

    100% {
      transform: translateY(calc(-50% - 0.5rem)) translateX(-0.75rem);
    }
  }
</style>
