---
import { CldImage } from "astro-cloudinary";
import { siteConfig } from "@config/site";
import { ArrowRight, CalendarDays, MapPin, MessageCircle } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

interface Props {
	hero: CollectionEntry<"landing">["data"]["hero"];
}

const { hero } = Astro.props;

const registrationHref = siteConfig.registrationUrl || hero.primaryCta.href;
const informativeGroupHref =
	siteConfig.informativeGroupUrl || hero.secondaryCta.href;

const isExternalRegistration = registrationHref.startsWith("http");
const isExternalGroup = informativeGroupHref.startsWith("http");
---

<section class="hero" aria-labelledby="landing-title">
	<div class="hero__copy">
		<h1 id="landing-title" class="hero__title">
			<span>{hero.titlePrefix}</span>
			<strong>{hero.titleHighlight}</strong>
		</h1>

		<p class="hero__description">{hero.description}</p>

		<dl class="hero__details">
			<div class="hero__detail">
				<div class="hero__icon" aria-hidden="true">
					<CalendarDays />
				</div>
				<div>
					<dt>{hero.date.label}</dt>
					<dd>{hero.date.value}</dd>
				</div>
			</div>

			<div class="hero__detail hero__detail--accent">
				<div class="hero__icon hero__icon--accent" aria-hidden="true">
					<MapPin />
				</div>
				<div>
					<dt>{hero.location.label}</dt>
					<dd>
						{
							hero.location.value.map((line) => (
								<Fragment>
									{line}
									<br />
								</Fragment>
							))
						}
					</dd>
				</div>
			</div>
		</dl>

		<div class="hero__actions">
			<a
				class="hero__action hero__action--primary"
				href={registrationHref}
				target={isExternalRegistration ? "_blank" : undefined}
				rel={isExternalRegistration ? "noopener noreferrer" : undefined}
			>
				{hero.primaryCta.label}
				<ArrowRight class="hero__action-icon" aria-hidden="true" />
			</a>

			<a
				class="hero__action hero__action--secondary"
				href={informativeGroupHref}
				target={isExternalGroup ? "_blank" : undefined}
				rel={isExternalGroup ? "noopener noreferrer" : undefined}
			>
				{hero.secondaryCta.label}
				<MessageCircle class="hero__action-icon" aria-hidden="true" />
			</a>
		</div>
	</div>

	<CldImage
		class="hero__logo-bg"
		src="branding/logo-hero"
		alt=""
		width={600}
		height={600}
		crop={{ type: 'fit', source: true }}
		loading="eager"
	/>
</section>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		align-items: center;
		gap: clamp(2rem, 4vw, 4.5rem);
		min-height: 100svh;
		overflow: hidden;
		background: var(--df-page);
		padding: clamp(7rem, 12vh, 9rem) clamp(1.25rem, 5vw, 4rem) clamp(3rem, 7vh, 5rem);
	}

	.hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 72% 22%,
			var(--df-primary-soft),
			transparent 28rem
		);
		pointer-events: none;
	}

	.hero__logo-bg {
		position: absolute;
		left: 50%;
		top: 50%;
		transform: translate(-50%, -50%);
		z-index: 1;
		width: min(90vw, 42rem) !important;
		height: auto !important;
		opacity: 0.32;
		pointer-events: none;
		object-fit: contain !important;
		animation: heroFloatMobile 10s ease-in-out infinite;
	}

	.hero__copy {
		position: relative;
		z-index: 2;
		width: 100%;
		max-width: 48rem;
		min-width: 0;
		text-align: center;
		margin-inline: auto;
	}

	.hero__title {
		margin: 0;
		color: var(--df-text);
		font-size: 2.4rem;
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: 0;
	}

	.hero__title span {
		display: block;
	}

	.hero__title strong {
		display: block;
		background: linear-gradient(90deg, var(--df-primary), var(--df-accent));
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		font-size: 3.4rem;
		line-height: 0.9;
	}

	.hero__description {
		max-width: 42rem;
		margin: clamp(1.5rem, 3vw, 2.25rem) auto 1.35rem;
		color: var(--df-text-muted);
		font-size: 1.1rem;
		line-height: 1.35;
	}

	.hero__details {
		display: grid;
		grid-template-columns: 1fr;
		gap: clamp(0.85rem, 1.5vw, 1.15rem);
	}

	.hero__detail {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 1.4rem;
		min-height: clamp(7rem, 9vw, 8.4rem);
		padding: clamp(0.85rem, 1.4vw, 1.1rem) clamp(1rem, 1.8vw, 1.35rem);
		border: 1px solid var(--df-line);
		border-radius: 0.45rem;
		background: var(--df-card);
		text-align: left;
		min-width: 0;
	}

	.hero__detail--accent {
		border-color: color-mix(in srgb, var(--df-primary) 50%, var(--df-line));
	}

	.hero__detail > div:last-child {
		min-width: 0;
	}

	.hero__icon {
		display: grid;
		place-items: center;
		width: clamp(4.75rem, 6vw, 6rem);
		height: clamp(4.75rem, 6vw, 6rem);
		border: 1px solid var(--df-accent-soft);
		border-radius: 0.6rem;
		color: var(--df-accent-soft);
	}

	.hero__icon--accent {
		border-color: var(--df-primary);
		color: var(--df-text-muted);
	}

	.hero__icon svg {
		width: 2rem;
		height: 2rem;
	}

	.hero__detail dt {
		display: block;
		color: var(--df-text-muted);
		font-size: var(--df-text-label);
		font-weight: 800;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.hero__detail dd {
		margin: 0.4rem 0 0;
		display: block;
		color: var(--df-text);
		font-size: 1.05rem;
		font-weight: 700;
		line-height: 1.45;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin-top: clamp(1.5rem, 2.5vw, 2rem);
		flex-direction: column;
		align-items: stretch;
	}

	.hero__action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: clamp(3.5rem, 4vw, 4rem);
		padding: 0.9rem clamp(1.5rem, 2.5vw, 2.2rem);
		font-size: 1.1rem;
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0;
		max-inline-size: 100%;
		text-align: center;
		width: 100%;
	}

	.hero__action--primary {
		background: var(--df-primary);
		color: var(--df-on-primary);
		box-shadow: 0 0 18px
			color-mix(in srgb, var(--df-primary) 45%, transparent);
	}

	.hero__action--secondary {
		border: 1px solid var(--df-accent);
		color: var(--df-accent);
	}

	.hero__action-icon {
		width: 1.4rem;
		height: 1.4rem;
		flex: 0 0 auto;
	}

	.hero__action:focus-visible {
		outline: 2px solid var(--df-accent);
		outline-offset: 4px;
	}

	@media (min-width: 640px) {
		.hero__details {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}
		.hero__actions {
			flex-direction: row;
		}
		.hero__action {
			width: auto;
			min-width: 16rem;
		}
	}

	@media (min-width: 1200px) {
		.hero {
			grid-template-columns: 1fr 1fr;
			gap: 2rem;
		}

		.hero__logo-bg {
			position: relative;
			left: auto;
			top: auto;
			transform: none;
			width: clamp(38rem, 48vw, 62rem) !important;
			opacity: 0.95;
			animation: heroFloatDesktop 10s ease-in-out infinite;
		}

		.hero__copy {
			text-align: left;
			margin-inline: 0;
			max-width: 44rem;
		}

		.hero__title { font-size: 4.25rem; }
		.hero__title strong { font-size: 6.6rem; }
		.hero__description { margin-inline: 0; font-size: 1.25rem; }
		.hero__detail dd { font-size: 1.15rem; }
		.hero__action { font-size: 1.3rem; }
	}

	@media (min-width: 1400px) {
		.hero__title { font-size: 5.25rem; }
		.hero__title strong { font-size: 8.25rem; }
		.hero__description { font-size: 1.35rem; }
		.hero__detail dd { font-size: 1.25rem; }
		.hero__action { font-size: 1.45rem; }
	}

	@keyframes heroFloatMobile {
		0%, 100% { transform: translate3d(-50%, -50%, 0); }
		50% { transform: translate3d(-50%, -53%, 0); }
	}

	@keyframes heroFloatDesktop {
		0%, 100% { transform: translate3d(0, 0, 0); }
		50% { transform: translate3d(0, -0.85rem, 0); }
	}
</style>
