---
import { getImagePath } from "@config/assets";
import { siteConfig } from "@config/site";
import { ArrowRight, CalendarDays, MapPin, MessageCircle } from "@lucide/astro";
import type { CollectionEntry } from "astro:content";

interface Props {
	hero: CollectionEntry<"landing">["data"]["hero"];
}

const { hero } = Astro.props;

const registrationHref = siteConfig.registrationUrl || hero.primaryCta.href;
const informativeGroupHref =
	siteConfig.informativeGroupUrl || hero.secondaryCta.href;

const isExternalRegistration = registrationHref.startsWith("http");
const isExternalGroup = informativeGroupHref.startsWith("http");
---

<section class="hero" aria-labelledby="landing-title">
	<div class="hero__copy">
		<h1 id="landing-title" class="hero__title">
			<span>{hero.titlePrefix}</span>
			<strong>{hero.titleHighlight}</strong>
		</h1>

		<p class="hero__description">{hero.description}</p>

		<dl class="hero__details">
			<div class="hero__detail">
				<div class="hero__icon" aria-hidden="true">
					<CalendarDays />
				</div>
				<div>
					<dt>{hero.date.label}</dt>
					<dd>{hero.date.value}</dd>
				</div>
			</div>

			<div class="hero__detail hero__detail--accent">
				<div class="hero__icon hero__icon--accent" aria-hidden="true">
					<MapPin />
				</div>
				<div>
					<dt>{hero.location.label}</dt>
					<dd>
						{
							hero.location.value.map((line) => (
								<Fragment>
									{line}
									<br />
								</Fragment>
							))
						}
					</dd>
				</div>
			</div>
		</dl>

		<div class="hero__actions">
			<a
				class="hero__action hero__action--primary"
				href={registrationHref}
				target={isExternalRegistration ? "_blank" : undefined}
				rel={isExternalRegistration ? "noopener noreferrer" : undefined}
			>
				{hero.primaryCta.label}
				<ArrowRight class="hero__action-icon" aria-hidden="true" />
			</a>

			<a
				class="hero__action hero__action--secondary"
				href={informativeGroupHref}
				target={isExternalGroup ? "_blank" : undefined}
				rel={isExternalGroup ? "noopener noreferrer" : undefined}
			>
				{hero.secondaryCta.label}
				<MessageCircle class="hero__action-icon" aria-hidden="true" />
			</a>
		</div>
	</div>

	<img
		class="hero__logo-bg"
		src={getImagePath("branding/logo-hero", {
			width: 600,
			height: 600,
			crop: "fit",
		})}
		alt=""
		width={600}
		height={600}
		loading="eager"
	/>
</section>

<style>
	.hero {
		position: relative;
		display: grid;
		grid-template-columns: 1fr;
		align-items: center;
		gap: 1.5rem;
		min-height: min(52rem, calc(100vh - 5rem));
		overflow: hidden;
		background: var(--df-page);
		padding: clamp(2.75rem, 8vw, 4.5rem) var(--df-section-x);
	}

	.hero::before {
		content: "";
		position: absolute;
		inset: 0;
		background: radial-gradient(
			circle at 72% 22%,
			var(--df-primary-soft),
			transparent 28rem
		);
		pointer-events: none;
	}

	.hero__logo-bg {
		position: relative;
		z-index: 1;
		justify-self: center;
		align-self: center;
		width: min(26rem, 78vw);
		height: auto;
		opacity: 0.28;
		max-width: none !important;
		max-height: none !important;
		aspect-ratio: auto !important;
		object-fit: contain !important;
		pointer-events: none;
		animation: heroFloat 10s ease-in-out infinite;
	}

	.hero__copy {
		position: relative;
		z-index: 2;
		width: 100%;
		max-width: 48rem;
		min-width: 0;
		text-align: center;
	}

	.hero__title {
		margin: 0;
		color: var(--df-text);
		font-size: 2.4rem;
		font-weight: 800;
		line-height: 1.05;
		letter-spacing: 0;
	}

	.hero__title span {
		display: block;
	}

	.hero__title strong {
		display: block;
		background: linear-gradient(90deg, var(--df-primary), var(--df-accent));
		background-clip: text;
		-webkit-background-clip: text;
		color: transparent;
		font-size: 3.4rem;
		line-height: 0.9;
	}

	.hero__description {
		max-width: 39rem;
		margin: 1.5rem auto 1.25rem;
		color: var(--df-text-muted);
		font-size: var(--df-text-body);
		line-height: 1.5;
	}

	.hero__details {
		display: grid;
		grid-template-columns: 1fr;
		gap: 1rem;
	}

	.hero__detail {
		display: grid;
		grid-template-columns: auto 1fr;
		align-items: center;
		gap: 1.4rem;
		min-height: 6.5rem;
		padding: 1rem;
		border: 1px solid var(--df-line);
		border-radius: 0.45rem;
		background: var(--df-card);
		text-align: left;
		min-width: 0;
	}

	.hero__detail--accent {
		border-color: color-mix(in srgb, var(--df-primary) 50%, var(--df-line));
	}

	.hero__detail > div:last-child {
		min-width: 0;
	}

	.hero__icon {
		display: grid;
		place-items: center;
		width: clamp(3.5rem, 18vw, 5rem);
		height: clamp(3.5rem, 18vw, 5rem);
		border: 1px solid var(--df-accent-soft);
		border-radius: 0.6rem;
		color: var(--df-accent-soft);
	}

	.hero__icon--accent {
		border-color: var(--df-primary);
		color: var(--df-text-muted);
	}

	.hero__icon svg {
		width: clamp(1.25rem, 5vw, 1.75rem);
		height: clamp(1.25rem, 5vw, 1.75rem);
	}

	.hero__detail dt {
		display: block;
		color: var(--df-text-muted);
		font-size: var(--df-text-label);
		font-weight: 800;
		letter-spacing: 0.2em;
		text-transform: uppercase;
	}

	.hero__detail dd {
		margin: 0.4rem 0 0;
		display: block;
		color: var(--df-text);
		font-size: 1.05rem;
		font-weight: 700;
		line-height: 1.45;
	}

	.hero__actions {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
		margin-top: clamp(1.5rem, 2.5vw, 2rem);
	}

	.hero__action {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		min-height: var(--df-touch-target);
		padding: 0.9rem 1.2rem;
		font-size: clamp(1rem, 0.95rem + 0.3vw, 1.2rem);
		font-weight: 700;
		text-decoration: none;
		letter-spacing: 0;
		max-inline-size: 100%;
		white-space: nowrap;
		text-align: center;
	}

	.hero__action--primary {
		background: var(--df-primary);
		color: var(--df-on-primary);
		box-shadow: 0 0 18px
			color-mix(in srgb, var(--df-primary) 45%, transparent);
	}

	.hero__action--secondary {
		border: 1px solid var(--df-accent);
		color: var(--df-accent);
	}

	.hero__action-icon {
		width: 1.4rem;
		height: 1.4rem;
		flex: 0 0 auto;
	}

	.hero__action:focus-visible {
		outline: 2px solid var(--df-accent);
		outline-offset: 4px;
	}

	@media (min-width: 640px) {
		.hero__details {
			grid-template-columns: repeat(2, minmax(0, 1fr));
		}

		.hero__actions {
			flex-direction: row;
		}

		.hero__action {
			width: auto;
			min-width: min(16rem, 100%);
		}
	}

	@media (max-width: 420px) {
		.hero__action {
			font-size: 0.95rem;
			padding-inline: 1rem;
		}
	}

	@media (min-width: 1024px) {
		.hero {
			grid-template-columns: minmax(0, 1fr) minmax(0, 43rem);
			gap: 2rem;
			min-height: calc(100vh - 8rem);
		}

		.hero__logo-bg {
			position: relative;
			left: auto;
			top: auto;
			transform: none;
			width: min(48rem, 48vw);
			opacity: 0.95;
		}

		.hero__copy {
			margin-inline: auto;
		}
	}

	@media (min-width: 901px) {
		.hero__title {
			font-size: 4.25rem;
		}

		.hero__title strong {
			font-size: 6.6rem;
		}

		.hero__description {
			font-size: 1.25rem;
		}

		.hero__detail dd {
			font-size: 1.15rem;
		}

		.hero__action {
			font-size: 1.3rem;
		}
	}

	@media (min-width: 1280px) {
		.hero__title {
			font-size: 5.25rem;
		}

		.hero__title strong {
			font-size: 8.25rem;
		}

		.hero__description {
			font-size: 1.35rem;
		}

		.hero__detail dd {
			font-size: 1.25rem;
		}

		.hero__action {
			font-size: 1.45rem;
		}
	}

	@keyframes heroFloat {
		0%,
		100% {
			transform: translate3d(0, 0, 0);
		}

		50% {
			transform: translate3d(0, -0.85rem, 0);
		}
	}
</style>
