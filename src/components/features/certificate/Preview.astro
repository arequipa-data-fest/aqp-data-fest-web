---
import { BadgeCheck, Share2 } from '@lucide/astro';
import { CldImage } from 'astro-cloudinary';
import type { CollectionEntry } from 'astro:content';

interface Props {
	data: CollectionEntry<'certificate'>['data']['preview'];
}

const { data } = Astro.props;
---

<section class="certificate-preview" aria-label={data.validationLabel} data-certificate-preview data-share-title={data.shareTitle} data-share-text={data.shareText}>
	<div class="certificate-preview__content">
		<CldImage class="certificate-preview__image" src={data.imageFilename} alt={data.imageAlt} width={data.imageWidth} height={data.imageHeight} loading="lazy" />
		<div class="certificate-preview__footer">
			<div class="certificate-preview__info"><div class="certificate-preview__icon" aria-hidden="true"><BadgeCheck /></div><div><p>{data.validationLabel}</p><span>{data.idLabel} {data.idValue}</span></div></div>
			<button class="certificate-preview__share" type="button" data-share-button aria-label={`${data.shareLabel}: ${data.shareTitle}`}><Share2 aria-hidden="true" />{data.shareLabel}</button>
		</div>
	</div>
</section>

<script>
	document.querySelectorAll('[data-certificate-preview]').forEach((preview) => {
		const button = preview.querySelector('[data-share-button]');
		const title = preview.getAttribute('data-share-title');
		const text = preview.getAttribute('data-share-text');
		if (!(button instanceof HTMLButtonElement) || !title || !text) return;
		button.addEventListener('click', async () => {
			try {
				const shareData = { title, text, url: window.location.href };
				if (navigator.share) await navigator.share(shareData);
				else await navigator.clipboard?.writeText(window.location.href);
			} catch (error) {
				if (error instanceof DOMException && error.name === 'AbortError') return;
				console.error('No se pudo compartir el certificado.', error);
			}
		});
	});
</script>

<style>
	.certificate-preview { background: var(--df-page); padding: 3rem 3.5rem; }
	.certificate-preview__content { max-width: 72rem; margin-inline: auto; }
	.certificate-preview__image { display: block; width: 100%; height: auto; border: 1px solid var(--df-line); border-radius: 0.3rem; box-shadow: 0 0 2rem color-mix(in srgb, var(--df-primary) 18%, transparent); }
	.certificate-preview__footer { display: flex; align-items: center; justify-content: space-between; gap: 1.5rem; margin-top: 1.5rem; }
	.certificate-preview__info { display: flex; min-width: 0; align-items: center; gap: 1rem; }
	.certificate-preview__icon { display: grid; width: 3rem; height: 3rem; flex: 0 0 auto; place-items: center; border-radius: 0.6rem; background: var(--df-card); color: var(--df-accent); }
	.certificate-preview__icon svg, .certificate-preview__share svg { width: 1.25rem; height: 1.25rem; flex: 0 0 auto; }
	.certificate-preview__info p { margin: 0; color: var(--df-text); font-size: var(--df-text-body); font-weight: 700; }
	.certificate-preview__info span { display: block; margin-top: 0.25rem; color: var(--df-text-muted); font-size: var(--df-text-label); overflow-wrap: anywhere; }
	.certificate-preview__share { display: inline-flex; align-items: center; gap: 0.5rem; border: 1px solid var(--df-accent); background: transparent; color: var(--df-accent); padding: 0.9rem 1.5rem; font: inherit; font-weight: 700; cursor: pointer; }
	.certificate-preview__share:focus-visible { outline: 2px solid var(--df-accent); outline-offset: 4px; }
	@media (max-width: 760px) { .certificate-preview { padding-inline: 1.25rem; } .certificate-preview__footer { align-items: flex-start; flex-direction: column; } }
</style>
