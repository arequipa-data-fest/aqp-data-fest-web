---
import { CldImage } from 'astro-cloudinary';

interface Tag {
	label: string;
}

interface Props {
	href: string;
	speakerId: string;
	variant: 'compact' | 'expanded' | 'featured';
	name: string;
	role: string;
	company?: string;
	imageFilename: string;
	imageAlt: string;
	badge?: string;
	tags?: Tag[];
	accent: 'primary' | 'accent';
	isRevealed?: boolean;
}

const {
	href,
	speakerId,
	variant,
	name,
	role,
	company,
	imageFilename,
	imageAlt,
	badge,
	tags = [],
	accent,
	isRevealed = false,
} = Astro.props;

const dimensions = {
	compact: { width: 424, height: 600 },
	expanded: { width: 566, height: 800 },
	featured: { width: 707, height: 1000 },
};

const width = dimensions[variant].width;
const height = dimensions[variant].height;

const displayImage = isRevealed ? imageFilename : 'speakers/incognito-placeholder';
const displayName = isRevealed ? name : 'Pronto';
const displayRole = isRevealed ? role : 'Speaker Invitado';
const transitionName = `speaker-hero-wrap-${speakerId}`;
const cardAriaLabel = isRevealed ? `Ver perfil de ${name}` : 'Ver perfil de ponente por revelar';
const compactClass = `speaker-card-compact speaker-card-compact--${accent}`;
const expandedClass = `speaker-card-expanded speaker-card-expanded--${accent}`;
const featuredClass = `speaker-card-featured speaker-card-featured--${accent}`;
---

{variant === 'compact' && (
	<a href={href} aria-label={cardAriaLabel} class={compactClass}>
		<div class="speaker-card-compact__image" transition:name={transitionName}>
			<CldImage
				src={displayImage}
				alt={imageAlt}
				width={width}
				height={height}
				crop="fill"
				gravity="auto"
				loading="lazy"
			/>
		</div>
		<div class="speaker-card-compact__details">
			{isRevealed && tags[0] && <span>{tags[0].label}</span>}
			<h3>{displayName}</h3>
		</div>
	</a>
)}

{variant === 'expanded' && (
	<a href={href} aria-label={cardAriaLabel} class={expandedClass}>
		<div class="speaker-card-expanded__image" transition:name={transitionName}>
			<CldImage
				src={displayImage}
				alt={imageAlt}
				width={width}
				height={height}
				crop={{ type: 'fill', gravity: 'face', source: true }}
				loading="lazy"
			/>
		</div>
		<div class="speaker-card-expanded__body">
			<h3>{displayName}</h3>
			<p>{displayRole} {isRevealed && company && ` | ${company}`}</p>
			{isRevealed && tags.length > 0 && (
				<ul class="speaker-card-expanded__tags">
					{tags.map((tag) => <li>{tag.label}</li>)}
				</ul>
			)}
		</div>
	</a>
)}

{variant === 'featured' && (
	<a href={href} aria-label={cardAriaLabel} class={featuredClass}>
		<div class="speaker-card-featured__image" transition:name={transitionName}>
			<CldImage
				src={displayImage}
				alt={imageAlt}
				width={width}
				height={height}
				crop={{ type: 'fill', gravity: 'face', source: true }}
				loading="lazy"
			/>
		</div>
		<div class="speaker-card-featured__content">
			{isRevealed && badge && <span class="speaker-card-featured__badge">{badge}</span>}
			<h3>{displayName}</h3>
			<p class="speaker-card-featured__role">{displayRole} {isRevealed && company && ` en ${company}`}</p>

			{isRevealed && tags.length > 0 && (
				<ul class="speaker-card-featured__tags">
					{tags.map((tag) => <li>{tag.label}</li>)}
				</ul>
			)}
		</div>
	</a>
)}

<style>
	/* Compact Styles (v1) */
	.speaker-card-compact { position: relative; display: grid; min-width: 0; min-height: 16rem; aspect-ratio: 1414 / 2000; overflow: hidden; align-items: end; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); border-radius: 0.3rem; background: var(--df-card); color: inherit; text-decoration: none; }
	.speaker-card-compact--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-compact--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-compact::after { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(to top, var(--df-page), transparent 65%); pointer-events: none; }
	.speaker-card-compact__image { position: absolute; inset: 0; }
	.speaker-card-compact img { position: absolute; inset: 0; display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-compact__details { position: relative; z-index: 2; min-width: 0; padding: 1.2rem; }
	.speaker-card-compact__details span { display: inline-flex; margin-bottom: 0.6rem; padding: 0.25rem 0.5rem; background: color-mix(in srgb, var(--df-page) 75%, transparent); color: var(--speaker-card-accent); font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
	.speaker-card-compact__details h3 { margin: 0; color: var(--df-text); font-size: clamp(1.2rem, 2vw, 1.6rem); font-weight: 800; line-height: 1.2; }
	.speaker-card-compact__details p { margin: 0.35rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); }

	/* Expanded Styles (v2) */
	.speaker-card-expanded { display: flex; flex-direction: column; min-width: 0; height: 100%; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); border-radius: 0.35rem; background: var(--df-card); color: inherit; text-decoration: none; }
	.speaker-card-expanded--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-expanded--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-expanded__image { position: relative; aspect-ratio: 1414 / 2000; overflow: hidden; }
	.speaker-card-expanded__image::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, var(--df-page), transparent 45%); pointer-events: none; }
	.speaker-card-expanded__image img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-expanded__body { display: flex; flex-direction: column; flex-grow: 1; padding: 1.5rem; background: var(--df-page); }
	.speaker-card-expanded__body h3 { margin: 0; color: var(--df-text); font-size: clamp(1.6rem, 6vw, 2.7rem); font-weight: 800; line-height: 1.2; word-break: normal; }
	.speaker-card-expanded__body > p { margin: 1rem 0 0; color: var(--speaker-card-accent); font-size: var(--df-text-body); font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; }
	.speaker-card-expanded__tags { display: flex; flex-wrap: wrap; gap: 0.65rem; margin-top: auto; padding: 1.5rem 0 0; list-style: none; }
	.speaker-card-expanded__tags li { border: 1px solid var(--df-line); padding: 0.45rem 0.85rem; color: var(--df-text-muted); font-size: var(--df-text-label); font-weight: 700; }

	/* Featured Styles (v3) */
	.speaker-card-featured { display: flex; flex-direction: column; min-width: 0; height: 100%; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); background: var(--df-page); color: inherit; text-decoration: none; }
	.speaker-card-featured--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-featured--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-featured__image { aspect-ratio: 1414 / 2000; overflow: hidden; background: var(--df-card); }
	.speaker-card-featured__image img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-featured__content { display: flex; min-width: 0; flex-direction: column; justify-content: center; flex-grow: 1; padding: 3rem; }
	.speaker-card-featured__badge { width: fit-content; margin-bottom: 1.5rem; border: 1px solid var(--speaker-card-accent); border-radius: 999px; background: color-mix(in srgb, var(--speaker-card-accent) 18%, transparent); color: var(--speaker-card-accent); padding: 0.4rem 1rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.12em; }
	.speaker-card-featured h3 { margin: 0; color: var(--df-text); font-size: clamp(1.8rem, 8vw, 4rem); font-weight: 900; line-height: 1.1; word-break: normal; }
	.speaker-card-featured__role { margin: 1rem 0 0; color: var(--speaker-card-accent); font-size: clamp(1rem, 3vw, 1.6rem); font-weight: 700; }
	.speaker-card-featured__description { max-width: 26rem; margin: 2rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); line-height: 1.5; }
	.speaker-card-featured__tags { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-top: auto; padding: 2rem 0 0; list-style: none; }
	.speaker-card-featured__tags li { border: 1px solid var(--df-line); background: var(--df-card); color: var(--df-text-muted); padding: 0.45rem 0.85rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.06em; }
	@media (min-width: 761px) { .speaker-card-featured { display: grid; grid-template-columns: 1fr 1fr; } .speaker-card-featured__image { aspect-ratio: auto; height: 100%; }
	}
	@media (max-width: 760px) { .speaker-card-featured { grid-template-columns: 1fr; } .speaker-card-featured__image { min-height: 22rem; } .speaker-card-featured__content { padding: 2rem; } }
</style>
