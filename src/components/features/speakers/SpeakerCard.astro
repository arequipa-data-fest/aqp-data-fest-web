---
import { getImagePath } from '@config/assets';

interface Tag {
	label: string;
}

interface Props {
	variant: 'compact' | 'expanded' | 'featured';
	name: string;
	role: string;
	company?: string;
	description?: string;
	imageFilename: string;
	imageAlt: string;
	imageWidth: number;
	imageHeight: number;
	badge?: string;
	tags?: Tag[];
	accent: 'primary' | 'accent';
}

const {
	variant,
	name,
	role,
	company,
	description,
	imageFilename,
	imageAlt,
	imageWidth,
	imageHeight,
	badge,
	tags = [],
	accent,
} = Astro.props;
---

<!-- Compact (v1) -->
{variant === 'compact' && (
	<article class:list={['speaker-card-compact', `speaker-card-compact--${accent}`]}>
		<img
			src={getImagePath(imageFilename)}
			alt={imageAlt}
			width={imageWidth}
			height={imageHeight}
			loading="lazy"
			decoding="async"
		/>
		<div class="speaker-card-compact__details">
			{tags[0] && <span>{tags[0].label}</span>}
			<h3>{name}</h3>
			{company && <p>{company}</p>}
		</div>
	</article>
)}

<!-- Expanded (v2) -->
{variant === 'expanded' && (
	<article class:list={['speaker-card-expanded', `speaker-card-expanded--${accent}`]}>
		<div class="speaker-card-expanded__image">
			<img
				src={getImagePath(imageFilename)}
				alt={imageAlt}
				width={imageWidth}
				height={imageHeight}
				loading="lazy"
				decoding="async"
			/>
		</div>
		<div class="speaker-card-expanded__body">
			<h3>{name}</h3>
			<p>{role}</p>
			{tags.length > 0 && (
				<ul class="speaker-card-expanded__tags">
					{tags.map((tag) => <li>{tag.label}</li>)}
				</ul>
			)}
		</div>
	</article>
)}

<!-- Featured (v3) -->
{variant === 'featured' && (
	<article class:list={['speaker-card-featured', `speaker-card-featured--${accent}`]}>
		<div class="speaker-card-featured__image">
			<img
				src={getImagePath(imageFilename)}
				alt={imageAlt}
				width={imageWidth}
				height={imageHeight}
				loading="lazy"
				decoding="async"
			/>
		</div>
		<div class="speaker-card-featured__content">
			{badge && <span class="speaker-card-featured__badge">{badge}</span>}
			<h3>{name}</h3>
			<p class="speaker-card-featured__role">{role}</p>
			{description && <p class="speaker-card-featured__description">{description}</p>}
			{tags.length > 0 && (
				<ul class="speaker-card-featured__tags">
					{tags.map((tag) => <li>{tag.label}</li>)}
				</ul>
			)}
		</div>
	</article>
)}

<style>
	/* Compact Styles (v1) */
	.speaker-card-compact { position: relative; display: grid; min-width: 0; min-height: 16rem; aspect-ratio: 1 / 1; overflow: hidden; align-items: end; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); border-radius: 0.3rem; background: var(--df-card); }
	.speaker-card-compact--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-compact--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-compact::after { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(to top, var(--df-page), transparent 65%); pointer-events: none; }
	.speaker-card-compact img { position: absolute; inset: 0; display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-compact__details { position: relative; z-index: 2; min-width: 0; padding: 1.2rem; }
	.speaker-card-compact__details span { display: inline-flex; margin-bottom: 0.6rem; padding: 0.25rem 0.5rem; background: color-mix(in srgb, var(--df-page) 75%, transparent); color: var(--speaker-card-accent); font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
	.speaker-card-compact__details h3 { margin: 0; color: var(--df-text); font-size: clamp(1.2rem, 2vw, 1.6rem); font-weight: 800; line-height: 1.2; }
	.speaker-card-compact__details p { margin: 0.35rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); }

	/* Expanded Styles (v2) */
	.speaker-card-expanded { min-width: 0; height: 100%; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); border-radius: 0.35rem; background: var(--df-card); }
	.speaker-card-expanded--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-expanded--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-expanded__image { position: relative; aspect-ratio: 1 / 1; overflow: hidden; }
	.speaker-card-expanded__image::after { content: ''; position: absolute; inset: 0; background: linear-gradient(to top, var(--df-page), transparent 45%); pointer-events: none; }
	.speaker-card-expanded__image img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-expanded__body { padding: 1.5rem; background: var(--df-page); }
	.speaker-card-expanded__body h3 { margin: 0; color: var(--df-text); font-size: clamp(2rem, 4vw, 2.7rem); font-weight: 800; line-height: 1.25; }
	.speaker-card-expanded__body > p { margin: 1rem 0 0; color: var(--speaker-card-accent); font-size: var(--df-text-body); font-weight: 800; letter-spacing: 0.15em; text-transform: uppercase; }
	.speaker-card-expanded__tags { display: flex; flex-wrap: wrap; gap: 0.65rem; margin: 1.5rem 0 0; padding: 0; list-style: none; }
	.speaker-card-expanded__tags li { border: 1px solid var(--df-line); padding: 0.45rem 0.85rem; color: var(--df-text-muted); font-size: var(--df-text-label); font-weight: 700; }

	/* Featured Styles (v3) */
	.speaker-card-featured { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); min-width: 0; height: 100%; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); background: var(--df-page); }
	.speaker-card-featured--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-featured--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-featured__image { min-height: 28rem; overflow: hidden; background: var(--df-card); }
	.speaker-card-featured__image img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-featured__content { display: flex; min-width: 0; flex-direction: column; justify-content: center; padding: 3rem; }
	.speaker-card-featured__badge { width: fit-content; margin-bottom: 1.5rem; border: 1px solid var(--speaker-card-accent); border-radius: 999px; background: color-mix(in srgb, var(--speaker-card-accent) 18%, transparent); color: var(--speaker-card-accent); padding: 0.4rem 1rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.12em; }
	.speaker-card-featured h3 { margin: 0; color: var(--df-text); font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 900; line-height: 1.15; }
	.speaker-card-featured__role { margin: 1.25rem 0 0; color: var(--speaker-card-accent); font-size: clamp(1.2rem, 2vw, 1.6rem); font-weight: 700; }
	.speaker-card-featured__description { max-width: 26rem; margin: 2rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); line-height: 1.5; }
	.speaker-card-featured__tags { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 2rem 0 0; padding: 0; list-style: none; }
	.speaker-card-featured__tags li { border: 1px solid var(--df-line); background: var(--df-card); color: var(--df-text-muted); padding: 0.45rem 0.85rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.06em; }
	@media (max-width: 760px) { .speaker-card-featured { grid-template-columns: 1fr; } .speaker-card-featured__image { min-height: 22rem; } .speaker-card-featured__content { padding: 2rem; } }
</style>
