---
import { getImagePath } from '@config/assets';

interface Speaker {
	name: string;
	company?: string;
	role: string;
	imageFilename: string;
	imageAlt: string;
	imageWidth: number;
	imageHeight: number;
	tags: { label: string }[];
}

interface Props {
	speaker: Speaker;
	accent: 'primary' | 'accent';
}

const { speaker, accent } = Astro.props;
---

<article class:list={['speaker-card-v1', `speaker-card-v1--${accent}`]}>
	<img
		src={getImagePath(speaker.imageFilename)}
		alt={speaker.imageAlt}
		width={speaker.imageWidth}
		height={speaker.imageHeight}
		loading="lazy"
		decoding="async"
	/>

	<div class="speaker-card-v1__details">
		{speaker.tags[0] && <span>{speaker.tags[0].label}</span>}
		<h3>{speaker.name}</h3>
		{speaker.company && <p>{speaker.company}</p>}
	</div>
</article>

<style>
	.speaker-card-v1 { position: relative; aspect-ratio: 1 / 1; overflow: hidden; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); border-radius: 0.3rem; background: var(--df-card); }
	.speaker-card-v1--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-v1--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-v1::after { content: ''; position: absolute; inset: 0; z-index: 1; background: linear-gradient(to top, var(--df-page), transparent 65%); pointer-events: none; }
	.speaker-card-v1 img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-v1__details { position: absolute; z-index: 2; left: 1.2rem; right: 1.2rem; bottom: 1rem; }
	.speaker-card-v1__details span { display: inline-flex; margin-bottom: 0.6rem; padding: 0.25rem 0.5rem; background: color-mix(in srgb, var(--df-page) 75%, transparent); color: var(--speaker-card-accent); font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; }
	.speaker-card-v1__details h3 { margin: 0; color: var(--df-text); font-size: clamp(1.2rem, 2vw, 1.6rem); font-weight: 800; line-height: 1.2; }
	.speaker-card-v1__details p { margin: 0.35rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); }
</style>
