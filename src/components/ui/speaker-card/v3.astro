---
import { getImagePath } from '@config/assets';

interface SpeakerTag {
	label: string;
}

interface Props {
	name: string;
	role: string;
	description?: string;
	imageFilename: string;
	imageAlt: string;
	imageWidth: number;
	imageHeight: number;
	badge?: string;
	tags?: SpeakerTag[];
	accent: 'primary' | 'accent';
}

const { name, role, description, imageFilename, imageAlt, imageWidth, imageHeight, badge, tags = [], accent } = Astro.props;
---

<article class:list={['speaker-card-v3', `speaker-card-v3--${accent}`]}>
	<div class="speaker-card-v3__image">
		<img
			src={getImagePath(imageFilename)}
			alt={imageAlt}
			width={imageWidth}
			height={imageHeight}
			loading="lazy"
			decoding="async"
		/>
	</div>

	<div class="speaker-card-v3__content">
		{badge && <span class="speaker-card-v3__badge">{badge}</span>}

		<h3>{name}</h3>
		<p class="speaker-card-v3__role">{role}</p>
		{description && <p class="speaker-card-v3__description">{description}</p>}

		{tags.length > 0 && (
			<ul class="speaker-card-v3__tags">
				{tags.map((tag) => <li>{tag.label}</li>)}
			</ul>
		)}
	</div>
</article>

<style>
	.speaker-card-v3 { display: grid; grid-template-columns: minmax(0, 1fr) minmax(0, 1fr); min-width: 0; height: 100%; border: 1px solid color-mix(in srgb, var(--speaker-card-accent) 55%, var(--df-line)); background: var(--df-page); }
	.speaker-card-v3--primary { --speaker-card-accent: var(--df-primary); }
	.speaker-card-v3--accent { --speaker-card-accent: var(--df-accent); }
	.speaker-card-v3__image { min-height: 28rem; overflow: hidden; background: var(--df-card); }
	.speaker-card-v3__image img { display: block; width: 100%; height: 100%; object-fit: cover; }
	.speaker-card-v3__content { display: flex; min-width: 0; flex-direction: column; justify-content: center; padding: 3rem; }
	.speaker-card-v3__badge { width: fit-content; margin-bottom: 1.5rem; border: 1px solid var(--speaker-card-accent); border-radius: 999px; background: color-mix(in srgb, var(--speaker-card-accent) 18%, transparent); color: var(--speaker-card-accent); padding: 0.4rem 1rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.12em; }
	.speaker-card-v3 h3 { margin: 0; color: var(--df-text); font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 900; line-height: 1.15; }
	.speaker-card-v3__role { margin: 1.25rem 0 0; color: var(--speaker-card-accent); font-size: clamp(1.2rem, 2vw, 1.6rem); font-weight: 700; }
	.speaker-card-v3__description { max-width: 26rem; margin: 2rem 0 0; color: var(--df-text-muted); font-size: var(--df-text-body); line-height: 1.5; }
	.speaker-card-v3__tags { display: flex; flex-wrap: wrap; gap: 0.75rem; margin: 2rem 0 0; padding: 0; list-style: none; }
	.speaker-card-v3__tags li { border: 1px solid var(--df-line); background: var(--df-card); color: var(--df-text-muted); padding: 0.45rem 0.85rem; font-size: var(--df-text-label); font-weight: 800; letter-spacing: 0.06em; }
	@media (max-width: 760px) { .speaker-card-v3 { grid-template-columns: 1fr; } .speaker-card-v3__image { min-height: 22rem; } .speaker-card-v3__content { padding: 2rem; } }
</style>
